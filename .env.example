# App
PNLCLAW_ENV=development
PNLCLAW_LOG_LEVEL=INFO

# Paths
PNLCLAW_DATA_DIR=./data
PNLCLAW_DB_PATH=./data/pnlclaw.db
PNLCLAW_DUCKDB_PATH=./data/pnlclaw.duckdb
PNLCLAW_LOG_DIR=./logs

# Local API
PNLCLAW_API_HOST=127.0.0.1
PNLCLAW_API_PORT=8080

# Exchange defaults
PNLCLAW_DEFAULT_EXCHANGE=binance
PNLCLAW_DEFAULT_SYMBOL=BTCUSDT
PNLCLAW_DEFAULT_TIMEFRAME=1m

# Binance API credentials (stored securely; configure via `pnlclaw setup`)
PNLCLAW_BINANCE_API_KEY=
PNLCLAW_BINANCE_API_SECRET=
PNLCLAW_BINANCE_TESTNET=false

# OKX API credentials
PNLCLAW_OKX_API_KEY=
PNLCLAW_OKX_API_SECRET=
PNLCLAW_OKX_PASSPHRASE=
PNLCLAW_OKX_DEMO=false

# Polymarket CLOB credentials
PNLCLAW_POLYMARKET_API_KEY=
PNLCLAW_POLYMARKET_API_SECRET=
PNLCLAW_POLYMARKET_PASSPHRASE=
PNLCLAW_POLYMARKET_WALLET_ADDRESS=

# Network proxy (required in mainland China — adjust port to match your proxy tool)
# Supports: socks5://host:port, http://host:port, https://host:port
# Leave empty if your network can reach Binance/OKX/Polymarket directly.
# Alternatively, set your system proxy to Global Mode and PnLClaw will auto-detect it.
PNLCLAW_PROXY_URL=

# WebSocket / market data
PNLCLAW_WS_ENABLED=true
PNLCLAW_L2_ENABLED=true
PNLCLAW_MARKET_CACHE_SIZE=10000
PNLCLAW_KLINE_INTERVALS=30m,1h
PNLCLAW_DEFAULT_SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT

# LLM provider
PNLCLAW_LLM_PROVIDER=openai_compatible
PNLCLAW_LLM_BASE_URL=
PNLCLAW_LLM_API_KEY=
PNLCLAW_LLM_MODEL=
PNLCLAW_LLM_TIMEOUT_SECONDS=60

# Safety defaults
PNLCLAW_ENABLE_REAL_TRADING=false
PNLCLAW_ENABLE_SHELL_TOOLS=false
PNLCLAW_ENABLE_FILE_WRITE_TOOLS=false
PNLCLAW_ENABLE_EXTERNAL_FETCH=false

# Backtest / paper trading
PNLCLAW_PAPER_STARTING_BALANCE=10000
PNLCLAW_BACKTEST_DEFAULT_CAPITAL=10000

# Feature flags
PNLCLAW_ENABLE_AGENT_DRAFTING=true
PNLCLAW_ENABLE_PAPER_TRADING=true
PNLCLAW_ENABLE_BACKTEST=true
